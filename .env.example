# Arc testnet RPC — loaded automatically from ~/.arc-canteen/env if you ran `arc-canteen login`.
# Do NOT paste the swrm_ token here; reference $RPC at runtime instead.
RPC=

# Direct (unproxied) Arc testnet RPC, useful for high-volume reads
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Chain
ARC_CHAIN_ID=5042002
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Agent's hot wallet (testnet only — never put mainnet keys here)
AGENT_PRIVATE_KEY=

# Circle dev platform (https://console.circle.com)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# LLM
ANTHROPIC_API_KEY=

# Venues
POLYMARKET_API_BASE=https://gamma-api.polymarket.com
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_EMAIL=
KALSHI_PASSWORD=

# Local storage
DB_PATH=./data/rfb2.sqlite
